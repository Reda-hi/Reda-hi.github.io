        ]
    },
    'fabric_scraps': {
        label: 'Fabric Scraps',
        category: 'Textile',
        image: 'https://www.shutterstock.com/shutterstock/videos/1098598647/thumb/1.jpg',
        videos: [
            { id: 'WOnSYLlHW0w', title: 'Fabric Scrap Quilts', duration: '19:45', views: '1.7M', difficulty: 'medium' }
        ]
    },
    'pallets': {
        label: 'Wood Pallets',
        category: 'Wood',
        image: 'https://www.liveabout.com/thmb/BWQ89ham_fTMrt2d6UMd9mIj1NY=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/94107208-56a7ec473df78cf7729ac1fd.jpg',
        videos: [
            { id: 'n_5OYAAP6ow', title: 'Pallet Furniture DIY', duration: '35:00', views: '5M', difficulty: 'hard' }
        ]
    }
};

let selectedMaterials = new Set();

// Navigation function
function switchSection(section) {
    // Hide all sections
    document.getElementById('intro-section').style.display = 'none';
    document.getElementById('search-section').style.display = 'none';
    document.getElementById('results-section').style.display = 'none';
    
    // Remove active from all nav tabs
    document.getElementById('navIntro').classList.remove('active');
    document.getElementById('navSearch').classList.remove('active');
    document.getElementById('navResults').classList.remove('active');
    
    // Show selected section and activate nav
    if (section === 'intro') {
        document.getElementById('intro-section').style.display = 'block';
        document.getElementById('navIntro').classList.add('active');
    } else if (section === 'search') {
        document.getElementById('search-section').style.display = 'block';
        document.getElementById('navSearch').classList.add('active');
    } else if (section === 'results') {
        document.getElementById('results-section').style.display = 'block';
        document.getElementById('navResults').classList.add('active');
    }
}

document.addEventListener('DOMContentLoaded', () => {
    renderCheckboxes();
});

function renderCheckboxes() {
    const list = document.getElementById('materialsList');
    
    Object.entries(materialsDB).forEach(([key, data]) => {
        const item = document.createElement('div');
        item.className = 'checkbox-item';
        item.dataset.key = key;  // Store key as data attribute for easy access
        
        item.innerHTML = `
            <input type="checkbox" id="${key}" value="${key}">
            <label for="${key}">
                <img src="${data.image}" alt="${data.label}" class="material-photo" onerror="this.src='https://via.placeholder.com/60?text=${encodeURIComponent(data.label)}'">
                <div class="material-info">
                    <span class="material-name">${data.label}</span>
                    <span class="material-category">${data.category}</span>
                </div>
            </label>
        `;
        
        // Attach event listener to checkbox
        const checkbox = item.querySelector('input[type="checkbox"]');
        checkbox.addEventListener('change', () => {
            updateSelection(key, checkbox.checked);
        });
        
        // Also allow clicking the entire item to toggle
        item.addEventListener('click', (e) => {
            if (e.target.tagName !== 'INPUT') {
                checkbox.checked = !checkbox.checked;
                updateSelection(key, checkbox.checked);
            }
        });
        
        list.appendChild(item);
    });
}

function updateSelection(key, isChecked) {
    if (isChecked) {
        selectedMaterials.add(key);
    } else {
        selectedMaterials.delete(key);
    }
    
    document.getElementById('countDisplay').textContent = selectedMaterials.size;
    document.getElementById('searchBtn').disabled = selectedMaterials.size === 0;
    
    // Find and update the visual state of the item
    const item = document.querySelector(`[data-key="${key}"]`);
    if (item) {
        if (isChecked) {
            item.classList.add('active');
        } else {
            item.classList.remove('active');
        }
    }
}

async function startAISearch() {
    const processing = document.getElementById('processingPanel');
    const progressFill = document.getElementById('progressBar');
    const log = document.getElementById('searchLog');
    
    document.getElementById('selectionPanel').style.display = 'none';
    processing.classList.add('active');
    progressFill.style.width = '0%';
    log.innerHTML = '';
    
    let progress = 0;
    const interval = setInterval(() => {
        progress = Math.min(90, progress + Math.random() * 15);
        progressFill.style.width = progress + '%';
    }, 300);
    
    try {
        log.innerHTML += `<div>🔍 Connecting to YouTube API...</div>`;
        
        const response = await fetch('http://localhost:5000/api/search', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({materials: Array.from(selectedMaterials)})
        });
        
        const data = await response.json();
        clearInterval(interval);
        progressFill.style.width = '100%';
        
        // Check API status
        if (data.api_status === 'failed' || data.api_status === 'not_configured') {
            log.innerHTML += `<div style="color: #dc2626; font-weight: bold;">⚠️ YouTube API Error</div>`;
            log.innerHTML += `<div>${data.message || data.error || 'API is not working'}</div>`;
            log.innerHTML += `<div>📱 Using local video database as fallback...</div>`;
        } else if (data.api_status === 'working') {
            log.innerHTML += `<div style="color: #10b981; font-weight: bold;">✓ YouTube API Connected!</div>`;
            log.innerHTML += `<div>Found ${data.total_videos} videos</div>`;
        }
        
        setTimeout(() => {
            processing.classList.remove('active');
            if (data.results && Object.keys(data.results).length > 0) {
                displayBackendResults(data.results);
            } else {
                log.innerHTML += `<div>⏳ No results from API, using local database...</div>`;
                displayResults();
            }
        }, 800);
    } catch (err) {
        clearInterval(interval);
        progressFill.style.width = '100%';
        log.innerHTML += `<div style="color: #dc2626; font-weight: bold;">❌ YouTube API Connection Failed</div>`;
        log.innerHTML += `<div>${err.message}</div>`;
        log.innerHTML += `<div>📱 Switching to offline mode with local videos...</div>`;
        
        setTimeout(() => {
            processing.classList.remove('active');
            displayResults();
        }, 800);
    }
}

function displayResults() {
    const grid = document.getElementById('videoGrid');
    
    let videos = [];
    selectedMaterials.forEach(mat => {
        if (materialsDB[mat] && materialsDB[mat].videos) {
            materialsDB[mat].videos.forEach(v => {
                videos.push({...v, source: materialsDB[mat].label, image: materialsDB[mat].image});
            });
        }
    });
    
    document.getElementById('resultCount').textContent = `${videos.length} videos`;
    
    // Show matched items
    const selectedItemsList = document.getElementById('selectedItemsList');
    selectedItemsList.innerHTML = '';
    selectedMaterials.forEach(mat => {
        if (materialsDB[mat]) {
            const badge = document.createElement('span');
            badge.style.cssText = 'display: inline-block; background: #d1fae5; color: #047857; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.875rem; font-weight: 500;';
            badge.textContent = materialsDB[mat].label;
            selectedItemsList.appendChild(badge);
        }
    });
    document.getElementById('selectedItemsDisplay').style.display = 'block';
    
    grid.innerHTML = '';
    videos.forEach((video, index) => {
        const card = document.createElement('div');
        card.className = 'video-card';
        card.innerHTML = `
            <div class="video-wrapper">
                <iframe src="https://www.youtube.com/embed/${video.id}" allowfullscreen></iframe>
            </div>
            <div class="video-content">
                <h3 class="video-title">${video.title}</h3>
                <div class="video-stats">
                    <span>👁️ ${video.views}</span>
                    <span>⏱️ ${video.duration}</span>
                </div>
                <span class="difficulty-badge difficulty-${video.difficulty}">${video.difficulty}</span>
                <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                    <img src="${video.image}" style="width: 100%; height: 140px; border-radius: 8px; object-fit: cover; margin-bottom: 0.5rem;">
                    <span style="font-size: 0.875rem; color: var(--text-light); font-weight: 600;">For: ${video.source}</span>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
    
    // Show results section
    switchSection('results');
    document.getElementById('navResults').style.display = 'block';
    document.getElementById('results-section').scrollIntoView({ behavior: 'smooth' });
}

function displayBackendResults(results) {
    const grid = document.getElementById('videoGrid');
    
    let videos = [];
    Object.entries(results).forEach(([material, items]) => {
        if (Array.isArray(items)) {
            items.forEach(v => {
                // Try to get material image from materialsDB
                const materialImage = materialsDB[material]?.image || 'https://via.placeholder.com/140?text=Material';
                videos.push({
                    id: v.id,
                    title: v.title,
                    views: v.views || '0',
                    duration: v.duration || 'N/A',
                    difficulty: v.difficulty || 'medium',
                    source: material.replace(/_/g, ' '),
                    image: materialImage
                });
            });
        }
    });
    
    document.getElementById('resultCount').textContent = `${videos.length} videos`;
    
    // Show matched items
    const selectedItemsList = document.getElementById('selectedItemsList');
    selectedItemsList.innerHTML = '';
    selectedMaterials.forEach(mat => {
        if (materialsDB[mat]) {
            const badge = document.createElement('span');
            badge.style.cssText = 'display: inline-block; background: #d1fae5; color: #047857; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.875rem; font-weight: 500;';
            badge.textContent = materialsDB[mat].label;
            selectedItemsList.appendChild(badge);
        }
    });
    document.getElementById('selectedItemsDisplay').style.display = 'block';
    
    grid.innerHTML = '';
    videos.forEach((video, index) => {
        const card = document.createElement('div');
        card.className = 'video-card';
        card.innerHTML = `
            <div class="video-wrapper">
                <iframe src="https://www.youtube.com/embed/${video.id}" allowfullscreen></iframe>
            </div>
            <div class="video-content">
                <h3 class="video-title">${video.title}</h3>
                <div class="video-stats">
                    <span>👁️ ${video.views}</span>
                    <span>⏱️ ${video.duration}</span>
                </div>
                <span class="difficulty-badge difficulty-${video.difficulty}">${video.difficulty}</span>
                <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                    <img src="${video.image}" style="width: 100%; height: 140px; border-radius: 8px; object-fit: cover; margin-bottom: 0.5rem;">
                    <span style="font-size: 0.875rem; color: var(--text-light); font-weight: 600;">For: ${video.source}</span>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
    
    // Show results section
    switchSection('results');
    document.getElementById('navResults').style.display = 'block';
    document.getElementById('results-section').scrollIntoView({ behavior: 'smooth' });
}
</script>

</body>
